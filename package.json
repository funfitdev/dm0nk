{
  "name": "bun-ssr",
  "module": "index.tsx",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "bun run build:css && bun run build:client && bun run build:server",
    "build:css": "tailwindcss -i ./styles.css -o ./dist/styles.css --minify",
    "build:client": "bun build ./public/client.ts --outdir ./dist --target browser --minify",
    "build:server": "NODE_ENV=production bun build ./index.tsx --outdir ./dist --target bun --minify",
    "dev": "bun run build:client && bun run --parallel dev:css dev:server",
    "dev:css": "tailwindcss -i ./styles.css -o ./dist/styles.css --watch",
    "dev:server": "NODE_ENV=production bun --watch run index.tsx",
    "start": "bun run build && bun dist/index.js",
    "db:generate": "drizzle-kit generate",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/cli": "^4.2.2",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10",
    "ssx": "file:./lib/ssx",
    "tailwindcss": "^4.2.2"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.9"
  }
}
